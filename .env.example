## MySQL
MYSQL_HOST=blog-mysql
MYSQL_DATABASE=yblog
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=password # 记得修改

## Redis
REDIS_HOST=blog-redis
REDIS_PORT=6379
REDIS_PASSWORD=

## Service Port (external)
PORT=80
APP_DOMAIN=blog.example.com

## DeepSeek AI
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=sk-你的deepseek密钥
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.3
AI_ENABLED=true

## Qiniu OSS
OSS_QINIU_ACCESS_KEY_ID=你的七牛云AK
OSS_QINIU_ACCESS_KEY_SECRET=你的七牛云SK
OSS_QINIU_BUCKET_NAME=你的bucket名称

## Resend Email
EMAIL_RESEND_API_KEY=re_你的resend密钥

## JWT Secret
JWT_SECRET=secret
JWT_ACCESS_TOKEN_EXPIRATION=300 # 5分钟
JWT_REFRESH_TOKEN_EXPIRATION=2592000 # 30天