## MySQL
MYSQL_HOST=blog-mysql
MYSQL_DATABASE=yblog
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=password

## Redis
REDIS_HOST=blog-redis
REDIS_PORT=6379
REDIS_PASSWORD=

## Service
SERVER_PORT=80
BACKEND_PORT=1145
APP_DOMAIN=blog.example.com
APP_URL=http://blog.example.com

## DeepSeek AI
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=sk-你的deepseek密钥
AI_MODEL=deepseek-chat
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.3
AI_ENABLED=true

## Storage type (local or oss)
STORAGE_TYPE=local

## Local Storage Path
LOCAL_STORAGE_PATH=uploads # 仅在 UPLOAD_STORAGE=local时生效

## Qiniu OSS
OSS_QINIU_ENDPOINT=端点
OSS_QINIU_ACCESS_KEY_ID=你的七牛云AK
OSS_QINIU_ACCESS_KEY_SECRET=你的七牛云SK
OSS_QINIU_BUCKET_NAME=你的bucket名称
OSS_QINIU_PATH_PREFIX=yblog/uploads

## Resend Email
EMAIL_RESEND_API_KEY=re_你的resend密钥

## JWT
JWT_SECRET=secret
JWT_ACCESS_TOKEN_EXPIRATION=300 # 5分钟
JWT_REFRESH_TOKEN_EXPIRATION=2592000 # 30天

## Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com